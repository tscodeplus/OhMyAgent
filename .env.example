# ============================================================================
# NOTE: config.yaml is now the recommended configuration method.
# Copy config.yaml.example → config.yaml and edit that instead.
# .env is still supported (and overrides config.yaml when both are present).
# Use ${VAR_NAME} in config.yaml to reference .env values for secrets.
# ============================================================================
#
# === Logging ===
# Pino log level: fatal | error | warn | info | debug | trace (default: info).
LOG_LEVEL=info

# === Server ===
# HTTP server port (default: 9191).
# OHMYAGENT_PORT=9191

# === LLM Provider ===
# Provider can be a built-in (deepseek, openai, anthropic, ...) or one defined in custom_providers.yaml
PI_AI_PROVIDER=deepseek
PI_AI_MODEL=deepseek-chat
PI_AI_REASONING_MODEL=deepseek-reasoner
PI_AI_API_KEY=sk-xxx
PI_AI_BASE_URL=

# === MiMo (optional) ===
MIMO_API_KEY=tp-xxx
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# === DeepSeek (optional, used by fallback models) ===
DEEPSEEK_API_KEY=sk-xxx

# === Reasoning ===
# Default reasoning level applied to all models unless overridden per-model in custom_providers.yaml.
# Accepts any string — provider-specific values like "low", "high", "max", "xhigh".
DEFAULT_REASONING_LEVEL=medium

# === Memory Auxiliary Models ===
# Shared model for all memory background tasks (query expansion, entity extraction,
# memory merge, summary). Provider/model-id format. Unset → rule-based fallback.
# MEMORY_AUX_MODEL=nvidia/deepseek-ai/deepseek-v4-flash
# MEMORY_AUX_FALLBACK_MODELS=nvidia/minimaxai/minimax-m2.7

# === Fallback Models ===
# Comma-separated list of fallback models tried in order when the primary model fails.
# Format: provider/model-id (references any registered model, built-in or custom).
FALLBACK_MODELS=ai-next/gpt-5.4,mimo/mimo-v2.5,deepseek/deepseek-v4-flash

# === Vision Bridge ===
# When enabled, images sent to text-only models (e.g. DeepSeek-V4) are first analyzed
# by a separate vision-capable model. The analysis is injected as text context so the
# text-only model can "see" images.
# See docs/VISION_BRIDGE_PLAN.md for full documentation.
VISION_BRIDGE_ENABLED=false

# Vision model identifier. Format: provider/model-id.
# Supports both built-in models (openai/gpt-4o-mini, anthropic/claude-haiku-4-5, ...)
# and custom provider models defined in custom_providers.yaml.
# VISION_BRIDGE_MODEL_REF=nvidia/moonshotai/kimi-k2.6

# Optional overrides. When unset, API key and base URL are auto-resolved:
#   Built-in models → from env var (OPENAI_API_KEY, ANTHROPIC_API_KEY, etc.)
#   Custom models   → from custom_providers.yaml
# VISION_BRIDGE_API_KEY=
# VISION_BRIDGE_BASE_URL=

# Analysis timeout in ms (default: 120000).
# VISION_BRIDGE_TIMEOUT_MS=120000
# Max characters per image analysis note (default: 3200).
# VISION_BRIDGE_MAX_NOTE_CHARS=3200
# Max cached analysis entries (default: 256).
# VISION_BRIDGE_MAX_CACHE_ENTRIES=256

# === Custom Providers (YAML file) ===
# Define custom providers in a YAML file. See custom_providers.yaml.example for the format.
CUSTOM_PROVIDERS_FILE=./custom_providers.yaml

# === Embedding (independent config) ===
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# === Feishu ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_CONNECTION_MODE=websocket

# === Telegram (optional) ===
# Bot token from @BotFather. Unset to disable Telegram integration.
# TELEGRAM_BOT_TOKEN=
# Connection mode: polling | webhook (default: polling).
# TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_SECRET=
# Comma-separated user/group IDs allowed to interact with the bot.
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_ALLOWED_GROUPS=
# HTTP proxy for bot API connections.
# TELEGRAM_PROXY_URL=
# Stream mode: edit (edit single message) | send (send new messages) (default: edit).
# TELEGRAM_STREAM_MODE=edit
# TELEGRAM_TEXT_LIMIT=4096
# Stream interval in ms (200–2000, default: 500).
# TELEGRAM_STREAM_INTERVAL=500

# === WeChat (optional) ===
# WECHAT_ENABLED=false
# WECHAT_BOT_TOKEN=
# WECHAT_API_BASE=https://ilinkai.weixin.qq.com
# WECHAT_CURSOR_DIR=./data/wechat
# WECHAT_TEXT_LIMIT=2048
# WECHAT_AES_KEY=
# WECHAT_ALLOWED_USERS=

# === QQ (optional) ===
# QQ_ENABLED=false
# QQ_APP_ID=
# QQ_CLIENT_SECRET=
# QQ_SANDBOX=false
# QQ_ALLOWED_USERS=
# QQ_ALLOWED_GROUPS=
# QQ_TEXT_LIMIT=1500

# === Database ===
# Database file path. Default ~/.ohmyagent/data/app.db
DATABASE_PATH=~/.ohmyagent/data/app.db

# === Rate Limit ===
RATE_LIMIT_WEBHOOK_MAX=100
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000

# === Web Search ===
# Provider order: comma-separated, tried left-to-right with automatic fallback.
# Supported: tavily (needs API key), exa (free MCP endpoint, 150 calls/day), baidu (needs 百度千帆 API key).
# Providers without API keys are skipped (except exa which falls back to free MCP).
WEB_SEARCH_PROVIDER=exa
WEB_SEARCH_TAVILY_API_KEY=
WEB_SEARCH_EXA_API_KEY=
WEB_SEARCH_BAIDU_API_KEY=
WEB_SEARCH_TIMEOUT_MS=30000
WEB_SEARCH_MAX_RESULTS=5

# === Cron ===
# Background task scheduler. Runs cron jobs defined in CRON_DATA_DIR.
# CRON_ENABLED=true
# CRON_TICK_INTERVAL_MS=30000
# CRON_DATA_DIR=./cron
# CRON_EXECUTION_TIMEOUT_MS=600000

# === Extensions ===
# Directory for dynamically loaded extensions.
# EXTENSIONS_DIRECTORY=extensions
# Path to agents configuration YAML file.
# AGENTS_CONFIG_PATH=agents.yaml

# === Display ===
# Show tool execution indicators in channel replies (🔧 name... / ✓ name). Default: true.
# Set to false to hide tool calls in message output.
SHOW_TOOL_CALLS=true

# === Tools ===
SHELL_ENABLED=true
SHELL_MAX_OUTPUT_CHARS=12000
SHELL_COMMAND_TIMEOUT_MS=60000

# -- v2 Permission Strategy --
# Tool Profile: minimal / standard / developer / full
TOOLS_PROFILE=standard
# Execution Mode: safe / balanced / trusted
SHELL_EXEC_MODE=balanced
# Argument-aware allowlist (format: program:subcommand or bare program name)
# Leave empty to use built-in SAFE_SUBSETS only
SHELL_ALLOWLIST=
# Approval timeout settings
SHELL_APPROVAL_TIMEOUT_SEC=120
SHELL_APPROVAL_TIMEOUT_ACTION=deny

# -- DEPRECATED v1 config (kept for backward compat, prefer TOOLS_PROFILE + SHELL_EXEC_MODE) --
SHELL_APPROVAL_MODE=balanced
SHELL_APPROVAL_WHITELIST=date,ls,pwd,whoami,uname,echo,cat,head,tail,wc,grep,find,which,env,printenv

# === File Read Security ===
# Allowed directories for file access (comma-separated). Project dir (cwd) is always included.
FILE_READ_ALLOWED_ROOTS=
# Denied file patterns (supports * glob). Applied on top of allowed roots.
FILE_READ_DENIED_PATTERNS=.env,"*.pem",/etc/passwd,"*/.ssh/*",config.yaml,agents.yaml,custom_providers.yaml

# === Memory ===
MEMORY_AUTO_RECALL=false
MEMORY_AUTO_RECALL_FREQUENCY=first
# MEMORY_AUTO_CAPTURE is deprecated — trigger-word auto-capture offers marginal benefit
# over LLM tool-call + MemorySummarizer. The config key is kept for backward compatibility
# but has no runtime effect.
MEMORY_RECALL_TOP_K=3
MEMORY_RECALL_MIN_SCORE=0.01
MEMORY_CAPTURE_MAX_CHARS=500
MEMORY_SUMMARIZE_INTERVAL=20
MEMORY_OUTPUT_LANGUAGE=Auto
# Temporal decay: half-life in days for retrieval scoring. 0 disables decay.
MEMORY_DECAY_HALF_LIFE_DAYS=30
# Embedding cache: max entries in SQLite cache table (LRU trim).
EMBEDDING_CACHE_MAX_ENTRIES=10000
# Memory hygiene: clean up temporary memories (fact/task/device_state) older than N days.
MEMORY_HYGIENE_ENABLED=true
MEMORY_HYGIENE_RETENTION_DAYS=90
# Circuit breaker for embedding API: trip after N consecutive failures, cooldown in seconds.
EMBEDDING_CB_FAILURE_THRESHOLD=5
EMBEDDING_CB_COOLDOWN_SEC=30

# === I18n ===
# UI display language for Feishu cards, command replies, and tool outputs.
# Valid values: en (default) | zh-CN
# NOTE: This is separate from MEMORY_OUTPUT_LANGUAGE (which controls LLM summary output language).
UI_LANGUAGE=en
