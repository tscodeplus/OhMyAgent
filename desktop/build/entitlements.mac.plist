<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow outgoing network connections -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Allow incoming connections (Fastify HTTP server on localhost) -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Allow JIT compilation (V8 JavaScript engine) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory (native Node.js addons like better-sqlite3, sharp) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Allow loading unsigned/third-party libraries (native .node addons) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Allow reading/writing user-selected files -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Allow Apple Events (for inter-process communication) -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
