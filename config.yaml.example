#     exec_mode: balanced         # safe | balanced | trusted
#     allowlist:
#       - date
#       - ls
#       - cat
#       - grep
#       - find
#     # command_timeout_ms: 60000
#     # max_output_chars: 12000
#     # approval_timeout_sec: 120
#     # approval_timeout_action: deny
#   file_read:
#     # allowed_roots:
#     #   - /tmp
#     #   - /home/user
#     # denied_patterns:
#     #   - .env
#     #   - "*.pem"

# --- Memory ---
# memory:
#   auto_recall: false
#   auto_recall_frequency: first   # first | every
#   summarize_interval: 20
#   output_language: Auto          # Auto | English | Simplified Chinese | ...
#   # recall_top_k: 3
#   # recall_min_score: 0.01
#   # capture_max_chars: 500
#   # decay_half_life_days: 30
#   # embedding_cache_max_entries: 10000
#   # query_embedding_timeout_ms: 10000
#   hygiene:
#     enabled: true
#     retention_days: 90
#   embedding_circuit_breaker:
#     failure_threshold: 5
#     cooldown_sec: 30

# --- Agents ---
# Define agent personas. Each key is an agent ID.
# The "default" agent is always present (built-in fallback if omitted).
# agents:
#   default:
#     name: Default
#     description: "General-purpose assistant"
#     system_prompt: "You are a helpful AI assistant."
#     tools:
#       profile: standard
#
#   coder:
#     name: Coder
#     description: "Developer assistant"
#     system_prompt: "You are a developer assistant. Help with code."
#     tools:
