# ============================================================================
# OhMyAgent Configuration
# ============================================================================
# Copy this file to config.yaml and edit the values you need.
# Only "provider" and one channel are required to get started.
#
# Environment variable interpolation:
#   Use ${VAR_NAME} to reference environment variables (e.g. ${OPENAI_API_KEY}).
#   This lets you keep secrets in .env while everything else lives here.
#
# Priority: process.env > config.yaml > defaults
# ============================================================================

# --- LLM Provider (required) ---
provider:
  # Format: provider/model-id (same format used by fallback_models and agents)
  primary: deepseek/deepseek-chat
  # Reasoning model (optional, defaults to primary model)
  reasoning: deepseek/deepseek-reasoner
  # API key — inline or use ${DEEPSEEK_API_KEY} to reference .env
  api_key: sk-xxx
  # Optional base URL override
  # base_url: https://api.deepseek.com/v1

# --- Fallback Models ---
# Tried in order when the primary model fails. Format: provider/model-id.
# fallback_models:
#   - mimo/mimo-v2.5
#   - deepseek/deepseek-v4-flash

# --- Default Reasoning Level ---
# Applied to all models unless overridden per-model in custom_providers.
# Accepts provider-specific values: low, medium, high, max, xhigh.
# default_reasoning_level: medium

# --- Summary LLM (optional) ---
# Used for session summarization. Falls back to rule-based summary if unset.
# summary:
#   model: deepseek/deepseek-chat
#   # api_key: sk-xxx
#   # base_url: https://api.deepseek.com/v1

# --- Vision Bridge (optional) ---
# When enabled, images sent to text-only models are first analyzed
# by a separate vision-capable model. See docs/VISION_BRIDGE_PLAN.md.
# vision_bridge:
#   enabled: true
#   model_ref: nvidia/moonshotai/kimi-k2.6
#   # timeout_ms: 120000

# --- Custom Providers (optional) ---
# Define LLM providers not in pi-mono's built-in registry.
# custom_providers:
#   ai-next:
#     api_key: sk-xxx
#     base_url: https://api.ai-next.top/v1
#     models:
#       - id: gpt-5.4
#         name: GPT-5.4
#         api: openai-responses         # or: openai-completions
#         reasoning: true
#         max_tokens: 128000
#         cost:
#           input: 0
#           output: 0
#           cache_read: 0
#           cache_write: 0

# --- Embedding ---
# embedding:
#   base_url: https://api.siliconflow.cn/v1
#   api_key: sk-xxx
#   model: BAAI/bge-m3
#   dimension: 1024

# --- Channels ---
# At least one channel must be configured.
channels:
  # feishu:
  #   enabled: true                     # Set to true to enable
  #   app_id: cli_xxx
  #   app_secret: yyy
  #   # verification_token: ""
  #   # encrypt_key: ""
  #   # connection_mode: websocket   # websocket | webhook

  # telegram:
  #   bot_token: xxx
  #   mode: polling               # polling | webhook
  #   proxy_url: http://127.0.0.1:7897

  # wechat:
  #   enabled: true
  #   bot_token: xxx

  # qq:
  #   enabled: true
  #   app_id: xxx
  #   client_secret: xxx

# --- Database ---
# database:
#   path: ~/.ohmyagent/data/app.db

# --- Web Search ---
# web_search:
#   provider_order:
#     - tavily
#     - exa
#     - baidu
#   # tavily_api_key: tvly-xxx
#   # baidu_api_key: bce-v3/xxx
#   # timeout_ms: 30000
#   # max_results: 5

