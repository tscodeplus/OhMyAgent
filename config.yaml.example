#     model:
#       primary: deepseek/deepseek-chat
#
#   designer:
#     name: Designer
#     description: "Design assistant"
#     system_prompt: "You are a design assistant. Help with UI/UX."
#     model:
#       primary: mimo/mimo-v2.5

# --- Cron (optional) ---
# cron:
#   enabled: true
#   tick_interval_ms: 30000
#   data_dir: ./cron
#   execution_timeout_ms: 600000

# --- Extensions ---
# extensions:
